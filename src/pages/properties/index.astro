---
import Base from '../../layouts/Base.astro';
import { PROPERTIES } from '../../data/properties';
---

<Base title="Properties" description="Evaluation properties for networking privacy">
  <div class="space-y-6">
    <nav class="text-[11px] font-mono mb-3" style="color: var(--c-text-3);">
      <a href="/" class="hover:underline">home</a> / properties
    </nav>
    <h1 class="text-2xl font-semibold tracking-tight">Properties</h1>
    <p class="text-[14px] mt-1 text-c-text-2">Properties used to evaluate the trade-offs of different design atoms.</p>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      {PROPERTIES.map(prop => (
        <a href={`/properties/${prop.id.toLowerCase()}`} class="block p-5 bg-white rounded-xl border border-c-border hover:border-c-border-strong hover:shadow-sm transition-all group">
          <div class="flex items-baseline gap-3 mb-2">
            <span class="font-mono font-bold text-lg text-c-text-3 group-hover:text-c-text transition-colors">{prop.id}</span>
            <h2 class="font-semibold text-c-text">{prop.name}</h2>
          </div>
          <p class="text-[13px] text-c-text-2 leading-relaxed">{prop.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
