---
import Base from '../layouts/Base.astro';
import GraphView from '../islands/GraphView';
---

<Base title="Dependency Graph" description="Interactive graph of networking privacy building blocks" wide>
  <div class="space-y-4">
    <nav class="text-[11px] font-mono mb-3" style="color: var(--c-text-3);">
      <a href="/" class="hover:underline">home</a> / graph
    </nav>
    <h1 class="text-2xl font-semibold tracking-tight">Dependency Graph</h1>
    <p class="text-[14px] mt-1 text-c-text-2">Force-directed layout of atom relationships. Click a node to inspect.</p>
    
    <div class="mt-8">
      <GraphView client:load />
    </div>
  </div>
</Base>
