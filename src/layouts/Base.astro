---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const { title = 'Ethereum Networking Privacy Map', description = 'A structured map of Ethereum networking privacy research', wide = false } = Astro.props;
const pageTitle = title === 'Ethereum Networking Privacy Map' ? title : `${title} — Ethereum Networking Privacy Map`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <Nav />
    <main class:list={[
      'px-6 py-10',
      wide ? 'max-w-[1400px] mx-auto' : 'mx-auto max-w-screen-xl',
    ]}>
      <slot />
    </main>
  </body>
</html>
